# Backend Production Environment Variables
# Copy this to backend/.env on your production server and fill in the values

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=mob_user
DB_PASSWORD=your_strong_db_password_here
DB_NAME=mob_barley
DB_SSL=false 

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend URL (your domain)
FRONTEND_BASE_URL=https://kanban.mnacar.com

# Security Secrets (same as root .env)
SESSION_SECRET=generate_random_string_here_min_32_chars
JWT_SECRET=generate_another_random_string_here_min_32_chars

# Email Configuration (optional - for password reset)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@mnacar.com
