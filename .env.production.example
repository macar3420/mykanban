# Production Environment Variables
# Copy this to .env on your production server and fill in the values

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your_strong_root_password_here
DB_USER=mob_user
DB_PASSWORD=your_strong_db_password_here
DB_NAME=mob_barley

# Frontend URL (your domain)
FRONTEND_BASE_URL=https://kanban.mnacar.com

# Security Secrets (IMPORTANT: Generate random strings, minimum 32 characters!)
# You can generate random strings with: openssl rand -base64 32
SESSION_SECRET=generate_random_string_here_min_32_chars
JWT_SECRET=generate_another_random_string_here_min_32_chars

# Email Configuration (optional - for password reset)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@mnacar.com
